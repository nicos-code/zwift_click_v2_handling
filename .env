# This value should stay "False"; I couldn't get encrypted communication to work, but I don't think
# it's really necessary anyway
USE_ENCRYPTION="False"

# if you want to connect to a specifc Click device, put it's MAC address here,
# otherwise the code will search for any Clicks within range

# CLICK_MAC_ADDRESS="DE:53:77:EB:6B:A1"

# Configure which keyboard keys are sent when the Click buttons are pressed
# Default values are 'num plus' and 'num minus' which work well for Training Peaks Virtual
# You can change these to any valid keyboard key names supported by the keyboard library

# Default configuration (TPV compatible):
# CLICK_PLUS_KEY="num plus"
# CLICK_MINUS_KEY="num minus"

# MyWhoosh configuration:
CLICK_PLUS_KEY="i"
CLICK_MINUS_KEY="k"

# Rouvy configuration:
# CLICK_PLUS_KEY="num plus"
# CLICK_MINUS_KEY="num minus"

# Simple arrow keys (may work with other apps):
# CLICK_PLUS_KEY="up"
# CLICK_MINUS_KEY="down"
